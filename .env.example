# =============================================================================
# Developer Automation Agent — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to VCS.
# =============================================================================

# ---------- LLM / OpenClaw ---------------------------------------------------
OPENCLAW_PROVIDER=openrouter          # openrouter | openai | ollama
OPENCLAW_API_KEY=
OPENCLAW_MODEL=openai/gpt-4o          # model identifier for the chosen provider
OPENCLAW_BASE_URL=                     # override for custom endpoints (Ollama, etc.)

# ---------- Slack ------------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=

# ---------- GitHub -----------------------------------------------------------
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=

# ---------- Jira -------------------------------------------------------------
JIRA_URL=https://your-org.atlassian.net
JIRA_USER=you@example.com
JIRA_API_TOKEN=
JIRA_WEBHOOK_SECRET=

# ---------- Confluence -------------------------------------------------------
CONFLUENCE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_USER=you@example.com
CONFLUENCE_API_TOKEN=

# ---------- Jenkins ----------------------------------------------------------
JENKINS_URL=https://jenkins.example.com
JENKINS_USER=
JENKINS_API_TOKEN=
JENKINS_WEBHOOK_SECRET=

# ---------- Gmail ------------------------------------------------------------
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# ---------- Server -----------------------------------------------------------
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080

# ---------- Database ---------------------------------------------------------
DATABASE_URL=sqlite:///data/agent.db
